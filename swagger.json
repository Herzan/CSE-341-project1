{
  "swagger": "2.0",
  "info": {
    "title": "Contacts API",
    "description": "Contacts API for managing contact records",
    "version": "1.0.0"
  },
  "host": "project1-8r7q.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {
    "/": {
      "get": {
        "description": "Test route",
        "responses": {
          "200": {
            "description": "API working"
          }
        }
      }
    },

    "/contacts": {
      "get": {
        "tags": ["Contacts"],
        "description": "Get all contacts",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Contacts retrieved successfully",
            "examples": {
              "application/json": [
                {
                  "firstName": "John",
                  "lastName": "Doe",
                  "email": "john@email.com",
                  "favoriteColor": "Blue",
                  "birthday": "1995-01-01"
                },
                {
                  "firstName": "Maria",
                  "lastName": "Lopez",
                  "email": "maria@email.com",
                  "favoriteColor": "Red",
                  "birthday": "1992-05-20"
                },
                {
                  "firstName": "Carlos",
                  "lastName": "Perez",
                  "email": "carlos@email.com",
                  "favoriteColor": "Green",
                  "birthday": "1990-03-10"
                },
                {
                  "firstName": "Ana",
                  "lastName": "Gomez",
                  "email": "ana@email.com",
                  "favoriteColor": "Purple",
                  "birthday": "1998-11-12"
                },
                {
                  "firstName": "David",
                  "lastName": "Smith",
                  "email": "david@email.com",
                  "favoriteColor": "Black",
                  "birthday": "1994-06-18"
                }
              ]
            }
          }
        }
      },

      "post": {
        "tags": ["Contacts"],
        "description": "Create a new contact",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "firstName",
                "lastName",
                "email",
                "favoriteColor",
                "birthday"
              ],
              "properties": {
                "firstName": {
                  "type": "string",
                  "example": "John"
                },
                "lastName": {
                  "type": "string",
                  "example": "Doe"
                },
                "email": {
                  "type": "string",
                  "example": "john@email.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "Blue"
                },
                "birthday": {
                  "type": "string",
                  "example": "1995-01-01"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact created successfully"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },

    "/contacts/{id}": {
      "get": {
        "tags": ["Contacts"],
        "description": "Get a single contact by ID",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact retrieved successfully"
          },
          "404": {
            "description": "Contact not found"
          }
        }
      },

      "put": {
        "tags": ["Contacts"],
        "description": "Update an existing contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "firstName": { "example": "Maria" },
                "lastName": { "example": "Lopez" },
                "email": { "example": "maria@email.com" },
                "favoriteColor": { "example": "Red" },
                "birthday": { "example": "1992-05-20" }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Contact updated"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },

      "delete": {
        "tags": ["Contacts"],
        "description": "Delete a contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Contact deleted"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}