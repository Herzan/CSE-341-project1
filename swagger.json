{
  "swagger": "2.0",
  "info": {
    "title": "Contacts API",
    "description": "API for managing contacts",
    "version": "1.0.0"
  },
  "host": "project1-8r7q.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {

    "/": {
      "get": {
        "tags": ["Test"],
        "description": "Test route to verify the API is running",
        "responses": {
          "200": {
            "description": "API working"
          }
        }
      }
    },

    "/users": {

      "get": {
        "tags": ["Contacts"],
        "summary": "Get all contacts",
        "description": "Returns a list of all contacts in the database",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Contacts retrieved successfully"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },

      "post": {
        "tags": ["Contacts"],
        "summary": "Create a new contact",
        "description": "Adds a new contact to the MongoDB database",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Contact object that needs to be added",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "firstName",
                "lastName",
                "email",
                "favoriteColor",
                "birthday"
              ],
              "properties": {
                "firstName": {
                  "type": "string",
                  "example": "John"
                },
                "lastName": {
                  "type": "string",
                  "example": "Doe"
                },
                "email": {
                  "type": "string",
                  "example": "john@email.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "Blue"
                },
                "birthday": {
                  "type": "string",
                  "example": "1995-01-01"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact created successfully"
          },
          "400": {
            "description": "Invalid input"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },

    "/users/{id}": {

      "get": {
        "tags": ["Contacts"],
        "summary": "Get a contact by ID",
        "description": "Returns a single contact based on the provided ID",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "MongoDB contact ID",
            "required": true,
            "type": "string",
            "example": "65fd2c9d6f21a5b30a8e1a01"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact retrieved successfully"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },

      "put": {
        "tags": ["Contacts"],
        "summary": "Update a contact",
        "description": "Updates an existing contact using the provided ID",
        "consumes": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "MongoDB contact ID",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Updated contact object",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "firstName",
                "lastName",
                "email",
                "favoriteColor",
                "birthday"
              ],
              "properties": {
                "firstName": {
                  "type": "string",
                  "example": "Maria"
                },
                "lastName": {
                  "type": "string",
                  "example": "Lopez"
                },
                "email": {
                  "type": "string",
                  "example": "maria@email.com"
                },
                "favoriteColor": {
                  "type": "string",
                  "example": "Red"
                },
                "birthday": {
                  "type": "string",
                  "example": "1992-05-20"
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Contact updated successfully"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },

      "delete": {
        "tags": ["Contacts"],
        "summary": "Delete a contact",
        "description": "Deletes a contact using the provided ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "MongoDB contact ID",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Contact deleted successfully"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}